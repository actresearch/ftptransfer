[Unit]
Description=ftptransfer Flask service
After=network.target

[Service]
Type=simple
User=actserver
Group=actserver
WorkingDirectory=/opt/ftptransfer
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/ftptransfer/.venv/bin/python /opt/ftptransfer/app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
